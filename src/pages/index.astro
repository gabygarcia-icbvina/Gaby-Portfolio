---
import Layout from '../layouts/Layout.astro';

const skills = [
  { name: 'Python',     icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/python/python-original.svg' },
  { name: 'HTML',       icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/html5/html5-original.svg' },
  { name: 'CSS',        icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/css3/css3-original.svg' },
  { name: 'JavaScript', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/javascript/javascript-original.svg' },
  { name: 'TypeScript', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/typescript/typescript-original.svg' },
  { name: 'VSCode',     icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/vscode/vscode-original.svg' },
  { name: 'GitHub',     icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/github/github-original.svg' },
  { name: 'React',      icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/react/react-original.svg' },
  { name: 'Windows',    icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/windows8/windows8-original.svg' },
  { name: 'Linux',      icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/linux/linux-original.svg' },
  { name: 'Cloudinary', icon: 'https://www.svgrepo.com/show/353566/cloudinary.svg' },
  { name: 'Vercel',     icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/vercel/vercel-original.svg' },
  { name: 'Astro',      icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/astro/astro-original.svg' },
  { name: 'Supabase',   icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/supabase/supabase-original.svg' },
  { name: 'Tailwind',   icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/tailwindcss/tailwindcss-original.svg' },
  { name: 'Node.js',    icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/nodejs/nodejs-original.svg' },
  { name: 'Git',        icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/git/git-original.svg' },
  { name: 'PostgreSQL', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/postgresql/postgresql-original.svg' },
  { name: 'Go',         icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/go/go-original.svg', learning: true },
];

const projects = [
  {
    title: 'Red Rabbit News',
    description: 'Student newspaper platform with full CMS, authentication, and article management.',
    tags: ['Astro', 'Supabase', 'Cloudinary', 'Tailwind'],
    url: 'https://rrnews.vercel.app',
    repo: 'https://github.com/gabygarcia-icbvina/Red-Rabbit-News-ICBVina',
  },
  {
    title: 'Café Demo',
    description: 'Landing page for a fictional café, showcasing responsive design and modern UI.',
    tags: ['Astro', 'Tailwind'],
    url: 'https://cafedemo-cl.vercel.app',
    repo: 'https://github.com/gabygarcia-icbvina/DEMO-Landing-Page-Cafeteria.git',
  },
  {
    title: 'Vota Informa',
    description: 'A web application that provides users with up-to-date information on local elections, candidates, and voting locations.',
    tags: ['Next.JS', 'CSS', "Typescript", 'Tailwind'],
    url: 'https://votainforma.vercel.app',
    repo: 'https://github.com/gg-herrera/Vota-Informa',
  },
  {
    title: 'Golf Sort',
    description: 'A new kind of sorting algorithm inspired by the game of golf, where elements are "putted" into their correct position in a way that minimizes the total number of moves.',
    tags: ['Python'],
    url: 'https://github.com/gg-herrera/GolfSort',
    repo: 'https://github.com/gg-herrera/GolfSort',
  }
];

const education = [
  {
    title: 'Estudiante Técnica Profesional en Programación',
    place: 'Instituto Superior de Comercio Alberto Blest Gana (ICBViña)',
    period: '2023 – 2026',
    description: 'Especialización en desarrollo de software, bases de datos y programación orientada a objetos.',
  },
];

const mainSkills    = skills.filter(s => !s.learning);
const learningSkills = skills.filter(s =>  s.learning);
const doubled       = [...mainSkills, ...mainSkills];
---

<Layout name="Main">

  <!-- ── NAV ─────────────────────────────────────────── -->
  <header class="fixed w-full h-16 bg-[#00112e] top-0 z-20 text-white flex items-center justify-between px-6">
    <span class="firacode text-sm opacity-50">gabygarciah-pro.vercel.app</span>
    <nav class="flex gap-6 text-2xl">
  <i class="fa-solid fa-file-code hover:scale-110 transition-all cursor-pointer" data-goto="about"     title="About"></i>
  <i class="fa-solid fa-briefcase  hover:scale-110 transition-all cursor-pointer" data-goto="projects"  title="Projects"></i>
  <i class="fa-solid fa-graduation-cap hover:scale-110 transition-all cursor-pointer" data-goto="education" title="Education"></i>
  <i class="fa-solid fa-envelope   hover:scale-110 transition-all cursor-pointer" data-goto="contact"   title="Contact"></i>
  <a href="/services" title="Services" class="hover:scale-110 transition-all">
    <i class="fa-solid fa-handshake"></i>
  </a>
</nav>
  </header>

  <main>

    <!-- ── HERO ─────────────────────────────────────────── -->
    <section class="hero min-h-screen flex flex-col items-center justify-center text-white text-center px-6">
      <img
        src="/gg.logo.webp"
        alt="Gaby García Logo"
        class="w-36 h-36 rounded-full mb-6 ring-2 ring-white/10"
      />
      <h1 class="firacode text-5xl font-bold mb-3">Gaby García</h1>
      <p class="firacode text-xl text-white/50 mb-8">Software Developer · Student</p>
      <div class="flex gap-4">
        <a data-goto="projects"
          class="px-5 py-2 rounded-full border border-white/20 hover:bg-white/10 transition firacode text-sm cursor-pointer">
          Ver proyectos
        </a>
        <a data-goto="contact"
          class="px-5 py-2 rounded-full bg-white text-[#00112e] hover:bg-white/90 transition firacode text-sm font-semibold cursor-pointer">
          Contacto
        </a>
      </div>
    </section>

    <!-- ── SKILLS MARQUEE ────────────────────────────────── -->
    <div class="skills-marquee" aria-label="Skills" role="region">
      <div class="marquee-track">
        {doubled.map(s => (
          <div class="skill-chip">
            <img src={s.icon} alt={s.name} width="18" height="18" />
            <span>{s.name}</span>
          </div>
        ))}
        {learningSkills.map(s => (
          <div class="skill-chip skill-chip--learning" title="Currently learning">
            <img src={s.icon} alt={s.name} width="18" height="18" />
            <span>{s.name}</span>
            <span class="learning-badge">learning</span>
          </div>
        ))}
      </div>
    </div>

    <!-- ── ABOUT ─────────────────────────────────────────── -->
    <section id="about" class="section text-white">
      <h2 class="section-title">About Me</h2>
      <p class="firacode text-white/70 text-lg max-w-2xl leading-relaxed">
        Hello! I am Gaby García, a passionate software developer and professional technitian
        programming student from <a href="https://www.insucoabg.cl" target="_blank" class="text-blue-400 hover:underline">ICBViña</a>
        . I have a strong interest in web development, cloud technologies, and learning new programming languages.
        I learn very fast and I am always eager to take on new challenges and collaborate on exciting projects. Welcome to my portfolio!
      </p>
    </section>

    <!-- ── PROJECTS ──────────────────────────────────────── -->
    <section id="projects" class="section text-white">
      <h2 class="section-title">Projects</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map(p => (
          <article class="project-card">
            <h3 class="firacode text-lg font-semibold mb-2">{p.title}</h3>
            <p class="text-white/60 text-sm mb-4 leading-relaxed">{p.description}</p>
            <div class="flex flex-wrap gap-2 mb-4">
              {p.tags.map(tag => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            <div class="flex gap-3 mt-auto">
              <a href={p.url} target="_blank" class="project-link"><i class="fa-solid fa-arrow-up-right-from-square"></i> Live</a>
              <a href={p.repo} target="_blank" class="project-link"><i class="fa-brands fa-github"></i> Repo</a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- ── EDUCATION ─────────────────────────────────────── -->
    <section id="education" class="section text-white">
      <h2 class="section-title">Education</h2>
      <div class="flex flex-col gap-6 max-w-2xl">
        {education.map(e => (
          <div class="edu-card">
            <span class="firacode text-xs text-white/40 mb-1 block">{e.period}</span>
            <h3 class="firacode text-lg font-semibold">{e.title}</h3>
            <span class="text-white/50 text-sm">{e.place}</span>
            <p class="text-white/60 text-sm mt-2 leading-relaxed">{e.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ── CONTACT ───────────────────────────────────────── -->
    <section id="contact" class="section text-white text-center">
      <h2 class="section-title mx-auto">Contact</h2>
      <p class="firacode text-white/50 mb-8">¿Tienes un proyecto o propuesta? Escríbeme.</p>
      <div class="flex justify-center gap-6 text-3xl">
        <a href="mailto:gabygarciah.pro@gmail.com" class="social-icon" title="Email">
          <i class="fa-solid fa-envelope"></i>
        </a>
        <a href="https://github.com/gabygarcia-icbvina" target="_blank" class="social-icon" title="GitHub">
          <i class="fa-brands fa-github"></i>
        </a>
        <a href="https://www.linkedin.com/in/gabygarciahpro/" target="_blank" class="social-icon" title="LinkedIn">
          <i class="fa-brands fa-linkedin"></i>
        </a>
      </div>
    </section>
    
  </main>

  <!-- ── FOOTER ────────────────────────────────────────── -->
  <footer class="text-center text-white/20 firacode text-xs py-8">
    © {new Date().getFullYear()} Gaby García · Built with Astro
  </footer>

</Layout>

<style>
  /* ── General ── */
  main { background: #00112e; }

  .section {
    padding: 80px 40px;
    max-width: 1100px;
    margin: 0 auto;
  }
  .section-title {
    font-family: 'Fira Code', monospace;
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 2rem;
    position: relative;
    display: inline-block;
  }
  .section-title::after {
    content: '';
    position: absolute;
    left: 0; bottom: -6px;
    width: 40px; height: 2px;
    background: rgba(255,255,255,0.3);
    border-radius: 2px;
  }

  /* ── Hero ── */
  .hero { background: #00112e; padding-top: 64px; }

  /* ── Marquee ── */
  .skills-marquee {
    background: #00112e;
    padding: 18px 0;
    overflow: hidden;
    position: relative;
    border-top: 1px solid rgba(255,255,255,0.08);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .skills-marquee::before,
  .skills-marquee::after {
    content: '';
    position: absolute;
    top: 0; bottom: 0;
    width: 80px;
    z-index: 2;
    pointer-events: none;
  }
  .skills-marquee::before { left: 0;  background: linear-gradient(to right, #00112e, transparent); }
  .skills-marquee::after  { right: 0; background: linear-gradient(to left,  #00112e, transparent); }
  .marquee-track {
    display: flex;
    width: max-content;
    animation: scroll-left 32s linear infinite;
  }
  .marquee-track:hover { animation-play-state: paused; }
  @keyframes scroll-left {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  .skill-chip {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 18px;
    margin: 0 8px;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.12);
    background: rgba(255,255,255,0.05);
    color: rgba(255,255,255,0.85);
    font-family: 'Fira Code', monospace;
    font-size: 13px;
    white-space: nowrap;
    transition: border-color 0.2s, background 0.2s;
    cursor: default;
  }
  .skill-chip:hover { border-color: rgba(255,255,255,0.35); background: rgba(255,255,255,0.1); }
  .skill-chip--learning { border-color: rgba(99,179,237,0.4); background: rgba(99,179,237,0.07); }
  .skill-chip img { width: 18px; height: 18px; object-fit: contain; }
  .learning-badge {
    font-size: 10px;
    padding: 2px 6px;
    border-radius: 999px;
    background: rgba(99,179,237,0.2);
    color: #63b3ed;
    border: 1px solid rgba(99,179,237,0.35);
  }

  /* ── Projects ── */
  .project-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s, background 0.2s;
  }
  .project-card:hover { border-color: rgba(255,255,255,0.2); background: rgba(255,255,255,0.07); }
  .tag {
    font-family: 'Fira Code', monospace;
    font-size: 11px;
    padding: 3px 10px;
    border-radius: 999px;
    background: rgba(255,255,255,0.07);
    color: rgba(255,255,255,0.5);
    border: 1px solid rgba(255,255,255,0.1);
  }
  .project-link {
    font-family: 'Fira Code', monospace;
    font-size: 12px;
    color: rgba(255,255,255,0.5);
    transition: color 0.2s;
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .project-link:hover { color: rgba(255,255,255,0.9); }

  /* ── Education ── */
  .edu-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 24px;
    border-left: 3px solid rgba(255,255,255,0.2);
  }

  /* ── Social ── */
  .social-icon {
    color: rgba(255,255,255,0.4);
    transition: color 0.2s, transform 0.2s;
  }
  .social-icon:hover { color: white; transform: scale(1.15); }
</style>

<script>
  document.querySelectorAll('[data-goto]').forEach(el => {
    el.addEventListener('click', () => {
      const id = el.getAttribute('data-goto')!;
      document.getElementById(id)?.scrollIntoView({ behavior: 'smooth' });
    });
  });
</script>